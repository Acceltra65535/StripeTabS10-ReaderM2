<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".terminal.TerminalFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textTerminalTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/terminal_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textConnectionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/status_not_initialized"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/textPaymentStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/status_payment_idle"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/textReaderStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/status_reader_not_selected"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/textTerminalHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/terminal_hint"
            android:textAppearance="?attr/textAppearanceBodySmall" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/amount_minor_units_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="@string/default_amount_minor_units" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/currency_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputCurrency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters"
                android:text="@string/default_currency" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDiscoverUsb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/action_discover_usb" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonConnectReader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/action_connect_reader" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLoadPaymentIntent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/action_load_payment_intent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCollectPayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/action_collect_payment" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCancelOperation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/action_cancel_operation"
            app:backgroundTint="?attr/colorSurfaceVariant" />

        <TextView
            android:id="@+id/textLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="?attr/colorSurfaceVariant"
            android:padding="12dp"
            android:text="@string/log_placeholder"
            android:textIsSelectable="true" />
    </LinearLayout>
</ScrollView>
